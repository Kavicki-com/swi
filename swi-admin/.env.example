# Copy this file to .env.local and fill in the values. .env.local is gitignored.

# ---- Mapbox -----------------------------------------------------------------
# Public token (pk.*) for the satellite tiles in /maps/general, /alerts and
# /alerts/:id/rescue. Get one at https://account.mapbox.com/access-tokens.
# IMPORTANT: restrict by URL (allowed origins) at the Mapbox dashboard —
# pk.* tokens are safe in client bundles only when origin-locked.
VITE_MAPBOX_TOKEN=pk.your_token_here

# ---- Figma (dev-time only, MCP tools) ---------------------------------------
FIGMA_DASHBOARD_URL=https://www.figma.com/design/your_file_key/your_file_name
FIGMA_DASHBOARD_FILE_KEY=your_file_key
FIGMA_DASHBOARD_NODE_ID=0:0
FIGMA_PAT=figd_your_personal_access_token
