{
  "expo": {
    "name": "SWI",
    "slug": "swi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111111"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kavicki.swi",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Permite tirar fotos para anexar a tarefas e relatórios.",
        "NSPhotoLibraryUsageDescription": "Permite selecionar fotos da galeria para anexar a tarefas e relatórios."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#111111"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.kavicki.swi",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@maplibre/maplibre-react-native",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite selecionar fotos da galeria para anexar a tarefas e relatórios.",
          "cameraPermission": "Permite tirar fotos para anexar a tarefas e relatórios."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "48d27919-4f34-41d6-a6e0-27e7689f55f7"
      }
    },
    "owner": "kavickicom"
  }
}
